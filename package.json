{
	"name": "ctd-todo-list",
	"version": "0.0.1",
	"private": true,
	"workspaces": [
		"client",
		"server",
		"shared"
	],
	"type": "module",
	"scripts": {
		"start": "npm run start --workspace=server",
		"dev": "concurrently \"npm:dev:*\"",
		"dev:server": "npm run dev --workspace=server",
		"dev:client": "npm run dev --workspace=client",
		"build": "npm run build:client && npm run build:server",
		"build:client": "npm run build --workspace=client",
		"build:server": "npm run build --workspace=server",
		"test": "concurrently \"npm:test:*\"",
		"test:server": "npm test --workspace=server --if-present",
		"test:client": "npm test --workspace=client --if-present",
		"typecheck": "concurrently --raw \"npm:typecheck:* --silent\"",
		"typecheck:server": "npm run typecheck --workspace=server",
		"typecheck:client": "npm run typecheck --workspace=client",
		"lint": "oxlint --fix . && concurrently --raw \"npm:lint:eslint:* --silent\"",
		"lint:eslint:server": "npm run lint --workspace=server",
		"lint:eslint:client": "npm run lint --workspace=client",
		"storybook": "npm run storybook --workspace=client",
		"prepare": "husky"
	},
	"devDependencies": {
		"@types/node": "24.13.2",
		"@typescript/native": "npm:typescript@^7.0.2",
		"concurrently": "10.0.3",
		"eslint": "10.6.0",
		"husky": "9.1.7",
		"nano-staged": "1.0.2",
		"oxfmt": "0.57.0",
		"oxlint": "1.72.0",
		"typescript": "npm:@typescript/typescript6@6.0.3",
		"typescript-eslint": "8.63.0"
	}
}
