{
	"name": "server",
	"version": "0.0.1",
	"private": true,
	"description": "Express server",
	"license": "MPL-2.0",
	"type": "module",
	"imports": {
		"#*": "./src/*",
		"#shared/*": "shared/*"
	},
	"scripts": {
		"build": "npm run db:generate && npm run db:deploy",
		"dev": "node --env-file-if-exists=.env --watch src/index.ts",
		"start": "node --env-file-if-exists=.env src/index.ts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc -b",
		"lint": "eslint --cache . --fix",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "prisma migrate deploy",
		"db:studio": "prisma studio",
		"db:flatten": "rm -rf prisma/migrations && prisma migrate reset --force && prisma migrate dev --name init"
	},
	"dependencies": {
		"@prisma/adapter-pg": "7.8.0",
		"@prisma/client": "7.8.0",
		"cors": "2.8.6",
		"express": "5.2.1",
		"google-auth-library": "10.9.0",
		"jose": "6.2.3",
		"prisma": "7.8.0",
		"shared": "*",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/cors": "2.8.19",
		"@types/express": "5.0.6",
		"@types/node": "24.13.2",
		"@types/supertest": "7.2.0",
		"supertest": "7.2.2",
		"typescript": "6.0.3",
		"vitest": "4.1.10"
	},
	"engines": {
		"node": ">=20.19"
	}
}
