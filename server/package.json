{
	"name": "server",
	"private": true,
	"version": "0.0.1",
	"description": "Express server",
	"license": "MPL-2.0",
	"type": "module",
	"imports": {
		"#app": "./src/app.ts",
		"#shared": "shared",
		"#*": "./src/*"
	},
	"scripts": {
		"dev": "node --env-file=.env --watch src/index.ts",
		"start": "node --env-file=.env src/index.ts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsgo -b",
		"lint": "eslint . --fix",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "prisma migrate deploy",
		"db:studio": "prisma studio",
		"db:flatten": "rm -rf prisma/migrations && prisma migrate reset --force && prisma migrate dev --name init",
		"postinstall": "prisma generate"
	},
	"engines": {
		"node": ">=20.19"
	},
	"dependencies": {
		"@prisma/adapter-pg": "7.8.0",
		"shared": "*",
		"@prisma/client": "7.8.0",
		"cors": "2.8.6",
		"express": "5.2.1",
		"jose": "6.2.3",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/cors": "2.8.19",
		"@types/express": "5.0.6",
		"@types/node": "24.12.4",
		"@types/supertest": "7.2.0",
		"prisma": "7.8.0",
		"supertest": "7.2.2",
		"typescript": "6.0.3",
		"vitest": "4.1.7"
	}
}
