# Copy to .env and adjust. Loaded by the Prisma CLI and by `npm run dev`/`start`
# (node --env-file=.env).

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ctd_todo_list?schema=public"

# Throwaway database for the test suite (vitest). Must be a SEPARATE database —
# the suite truncates its tables between tests. CI must provision this and set it.
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ctd_todo_list_test?schema=public"

# Secret used to sign session JWTs. Required in production; a random ephemeral
# secret is used in development if unset.
# AUTH_SECRET="change-me"

# Google OAuth 2 credentials. Create an OAuth 2.0 Client ID in the Google Cloud
# Console, add the redirect URI below to the list of authorized redirect URIs.
# GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-client-secret"
# GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/google/callback"

# Where to send the browser after a successful Google OAuth login.
# CLIENT_ORIGIN="http://localhost:3000"
