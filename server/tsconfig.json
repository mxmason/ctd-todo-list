{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"lib": ["ES2022"],
		"types": ["node"],
		"allowSyntheticDefaultImports": true,
		"allowImportingTsExtensions": true,
		"incremental": true,
		"tsBuildInfoFile": "./node_modules/.cache/tsc/tsconfig.tsbuildinfo"
	},
	"include": ["src"]
}
