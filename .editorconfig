root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = tab
insert_final_newline = true
trim_trailing_whitespace = true

# Windows-only scripts use CRLF (matches .gitattributes)
[*.{bat,cmd,ps1}]
end_of_line = crlf

# YAML and Markdown conventionally use spaces
[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
