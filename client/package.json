{
	"name": "client",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"imports": {
		"#shared/*": "shared/*",
		"#storybook/*": "./.storybook/*",
		"#test": "./src/test/test-utils.tsx",
		"#*": [
			"./src/*",
			"./src/*/index.ts",
			"./src/*/index.tsx"
		]
	},
	"scripts": {
		"test": "vitest run",
		"dev": "vite --host",
		"build": "vite build",
		"preview": "vite preview",
		"typecheck": "tsc -b",
