{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../tsconfig.base.json",
	"compilerOptions": {
		"lib": ["ES2022", "DOM"],
		"jsx": "react-jsx",
		"useDefineForClassFields": true,
		"allowImportingTsExtensions": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"paths": {
			"#shared": ["../shared/dist/index.d.ts"],
			"#storybook/*": ["./.storybook/*"]
		},
		"composite": true,
		"incremental": true,
		"tsBuildInfoFile": "./node_modules/.cache/tsc/tsconfig.app.tsbuildinfo"
	},
	"references": [{ "path": "../shared" }],
	"include": ["src", ".storybook/preview.tsx"]
}
